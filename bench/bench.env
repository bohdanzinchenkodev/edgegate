# Ports
UPSTREAM_PORT=9100
PROXY_PORT=8001

# Routing
TARGET_HOST=svc0.example.com

# Docker
DOCKER_NETWORK=edgegate-bench
EDGEGATE_IMAGE=edgegate
EDGEGATE_CONTAINER=edgegate-proxy
VEGETA_IMAGE=edgegate-vegeta

# Paths
BENCH_DIR=/tmp/edgegate-bench

# Load test defaults
RATE=10000
DURATION=30s
WORKERS=500
CONNECTIONS=5000
